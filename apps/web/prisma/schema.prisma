model InventoryStockCategory {
  id             String      @id @default(uuid())
  name           String
  tallyId        String?     @map("tally_id")
  parentCategory String?     @map("parent_category")
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_stock_categories")
}

model InventoryUnit {
  id             String      @id @default(uuid())
  name           String
  tallyId        String?     @map("tally_id")
  originalName   String?     @map("original_name")
  decimalPlaces  Int         @default(0) @map("decimal_places")
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_units")
}

model InventoryGodown {
  id             String      @id @default(uuid())
  name           String
  tallyId        String?     @map("tally_id")
  parentGodown   String?     @map("parent_godown")
  address        String?
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_godowns")
}

model InventoryPriceLevel {
  id             String      @id @default(uuid())
