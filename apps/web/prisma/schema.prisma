  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_price_levels")
}

model InventoryBatch {
  id             String      @id @default(uuid())
  name           String
  tallyId        String?     @map("tally_id")
  stockItemId    String      @map("stock_item_id")
  mfgDate        DateTime?   @map("mfg_date")
  expiryDate     DateTime?   @map("expiry_date")
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_batches")
}

model InventoryStockItem {
  id               String      @id @default(uuid())
  name             String
  alias            String?
  sku              String?     @unique
  barcode          String?
  hsnCode          String?     @map("hsn_code")
  gstRate          Decimal?    @map("gst_rate")
  stockGroup       String?     @map("stock_group")
  stockCategory    String?     @map("stock_category")
  unit             String
  godown           String?
  
  // Future ERP Tracking
  manufacturer     String?
  brand            String?
  isBatchTracking  Boolean     @default(false) @map("is_batch_tracking")
  isSerialTracking Boolean     @default(false) @map("is_serial_tracking")
  isExpiryTracking Boolean     @default(false) @map("is_expiry_tracking")
  mfgDate          DateTime?   @map("mfg_date")
  metadata         Json?
  
  payload          Json
  syncStatus       SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt       DateTime?   @map("last_sync_at")
  syncAttempts     Int         @default(0) @map("sync_attempts")
  lastSyncError    String?     @map("last_sync_error")
  xmlRequest       String?     @map("xml_request")
  xmlResponse      String?     @map("xml_response")
  
  // Audit & Lifecycle
  correlationId    String?     @map("correlation_id")
  sourceSystem     String      @default("TallyMe") @map("source_system")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  createdBy        String?     @map("created_by")
  updatedBy        String?     @map("updated_by")

  organizationId   String      @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_stock_items")
}

// ==========================================
// STUDENT FEES BOUNDED CONTEXT
// ==========================================

model IngestionMessage {
  id             String    @id @default(uuid())
  provider       String    // GMAIL, OUTLOOK, etc.
  messageId      String    @map("message_id")
  threadId       String?   @map("thread_id")
  historyId      String?   @map("history_id")
  labelIds       Json?     @map("label_ids")
  subject        String?
  fromEmail      String?   @map("from_email")
  payloadHash    String    @map("payload_hash") // Semantic duplication
  status         String    @default("PENDING") // PENDING, PUBLISHED, FAILED
  
  // Audits & Error tracking
  retryCount     Int       @default(0) @map("retry_count")
  lastError      String?   @map("last_error")
  receivedAt     DateTime  @map("received_at")
  processedAt    DateTime? @map("processed_at")
  
  // Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organizationId String    @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Composite constraints to prevent identical Message IDs per provider
  @@unique([provider, messageId], name: "uq_ingestion_messages_provider_msg")
  @@index([provider, status], name: "idx_ingestion_messages_status")
  @@index([payloadHash], name: "idx_ingestion_messages_hash")
  @@map("ingestion_messages")
}

// ==========================================
// STUDENT INFORMATION SYSTEM
// ==========================================

model FeeHead {
  id                 String    @id @default(uuid())
  name               String
  priority           Int       @default(999)
  type               String    // e.g. TUITION, TRANSPORT, LATE_FEE, ADVANCE
  active             Boolean   @default(true)

  // Audits & Lifecycle
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])
  
  feeStructureItems  FeeStructureItem[]
  allocations        FeeTransactionAllocation[]

  @@map("fee_heads")
}

model FeeStructure {
  id                 String    @id @default(uuid())
  name               String
  
  // Audits & Lifecycle
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])
  
  students           StudentProfile[]
  items              FeeStructureItem[]
  feeTransactions    FeeTransaction[]
  
  @@map("fee_structures")
}

model FeeStructureItem {
  id                 String    @id @default(uuid())
  feeStructureId     String    @map("fee_structure_id")
  feeHeadId          String    @map("fee_head_id")
  amount             Decimal   @default(0)

  feeStructure       FeeStructure @relation(fields: [feeStructureId], references: [id])
  feeHead            FeeHead      @relation(fields: [feeHeadId], references: [id])

  @@unique([feeStructureId, feeHeadId], name: "uq_fee_structure_item")
  @@map("fee_structure_items")
}

model StudentProfile {
  id                 String    @id @default(uuid())
  admissionNumber    String    @unique @map("admission_number")
  rollNumber         String?   @map("roll_number")
  studentName        String    @map("student_name")
  fatherName         String?   @map("father_name")
  motherName         String?   @map("mother_name")
  class              String
  section            String?
  academicSession    String    @map("academic_session")
  status             String    @default("ACTIVE") // ACTIVE, INACTIVE, ALUMNI
  phone              String?
  email              String?
  metadata           Json?
  
  feeStructureId     String?   @map("fee_structure_id")
  feeStructure       FeeStructure? @relation(fields: [feeStructureId], references: [id])
  
  feeTransactions    FeeTransaction[]

  // Audits & Lifecycle
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([admissionNumber], name: "idx_students_admission_no")
  @@index([studentName, class], name: "idx_students_name_class")
  @@map("student_profiles")
}

// ==========================================
// STUDENT FEES BOUNDED CONTEXT (MATCHING & EXCEPTIONS)
// ==========================================

model ManualReview {
  id                 String    @id @default(uuid())
  type               String    // MATCHING_FAILURE, OVERPAYMENT, DUPLICATE
  reason             String
  status             String    @default("PENDING") // PENDING, RESOLVED
  payload            Json      // The original PaymentNotification or context
  resolution         String?
  assignedTo         String?   @map("assigned_to")
  
  // Audits & Lifecycle
  createdAt          DateTime  @default(now()) @map("created_at")
  resolvedAt         DateTime? @map("resolved_at")

  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([status, type], name: "idx_manual_reviews_status")
  @@map("manual_reviews")
}

model FeeTransaction {
  id                      String    @id @default(uuid())
  studentId               String    @map("student_id")
  paymentNotificationId   String?   @map("payment_notification_id")
  feeStructureId          String    @map("fee_structure_id")
  expectedAmount          Decimal   @map("expected_amount")
  receivedAmount          Decimal   @map("received_amount")
  balanceRemaining        Decimal   @map("balance_remaining")
  
  billingPeriod           String    @default("MONTHLY") @map("billing_period") // MONTHLY, QUARTERLY, ANNUAL
  feeMonth                String?   @map("fee_month")
  
  paymentDate             DateTime  @map("payment_date")
  gateway                 String?
  utr                     String?
  status                  String    @default("PENDING") // PAID, PARTIALLY_PAID, OVERPAID, ADVANCE_PAYMENT
  remarks                 String?
  metadata                Json?

  // Audits & Lifecycle
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  
  organizationId          String    @map("organization_id")
  organization            Organization @relation(fields: [organizationId], references: [id])

  student                 StudentProfile @relation(fields: [studentId], references: [id])
  feeStructure            FeeStructure   @relation(fields: [feeStructureId], references: [id])
  allocations             FeeTransactionAllocation[]

  @@index([studentId, paymentDate], name: "idx_fee_transactions_student_date")
  @@map("fee_transactions")
}

model FeeTransactionAllocation {
  id                 String    @id @default(uuid())
  feeTransactionId   String    @map("fee_transaction_id")
  feeHeadId          String    @map("fee_head_id")
  
  expectedAmount     Decimal   @map("expected_amount")
  allocatedAmount    Decimal   @map("allocated_amount")
  remainingAmount    Decimal   @map("remaining_amount")
  priority           Int

  feeTransaction     FeeTransaction @relation(fields: [feeTransactionId], references: [id])
  feeHead            FeeHead        @relation(fields: [feeHeadId], references: [id])

  @@index([feeTransactionId], name: "idx_fee_allocations_txn")
  @@map("fee_transaction_allocations")
}

// ==========================================
// ACCOUNTING MAPPER (ANTI-CORRUPTION LAYER)
// ==========================================

model LedgerMapping {
  id                 String    @id @default(uuid())
  mappingKey         String    @map("mapping_key") // e.g. 'FEE_HEAD_TUITION', 'BANK_HDFC'
  ledgerId           String    @map("ledger_id")
  
  // Audits & Lifecycle
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])
  ledger             AccountingLedger @relation(fields: [ledgerId], references: [id])

  @@unique([organizationId, mappingKey], name: "uq_ledger_mapping")
  @@map("ledger_mappings")
}

model AccountingTransaction {
  id                 String    @id @default(uuid())
  referenceId        String    @map("reference_id") // ID from business domain
  referenceType      String    @map("reference_type") // e.g. 'FEE_RECEIPT'
  transactionDate    DateTime  @map("transaction_date")
  description        String?
  voucherType        String    @map("voucher_type") // RECEIPT, PAYMENT, JOURNAL
  status             String    @default("PENDING") // PENDING, GENERATED, FAILED
  
  // Immutability & Idempotency
  version            Int       @default(1)
  sourceEventId      String    @unique @map("source_event_id") // Correlates to FeeAllocated eventId
  
  // Audits & Lifecycle
  createdBy          String    @default("SYSTEM") @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])
  
  entries            AccountingEntry[]
  accountingVoucher  AccountingVoucher?

  @@index([referenceId, referenceType], name: "idx_acct_txn_reference")
  @@map("accounting_transactions")
}

model AccountingEntry {
  id                 String    @id @default(uuid())
  transactionId      String    @map("transaction_id")
  ledgerId           String    @map("ledger_id")
  
  debit              Decimal   @default(0)
  credit             Decimal   @default(0)
  costCenter         String?   @map("cost_center")
  narration          String?
  metadata           Json?
  
  transaction        AccountingTransaction @relation(fields: [transactionId], references: [id])
  ledger             AccountingLedger      @relation(fields: [ledgerId], references: [id])

  @@index([transactionId], name: "idx_acct_entry_txn")
  @@map("accounting_entries")
}

model SyncSession {
  id               String    @id @default(uuid())
  voucherId        String    @map("voucher_id")
  attempt          Int
  status           SyncStatus
  
  startedAt        DateTime  @default(now()) @map("started_at")
  completedAt      DateTime? @map("completed_at")
  duration         Int?      // Duration in milliseconds
  
  response         Json?
  error            String?
  correlationId    String?   @map("correlation_id")

  voucher          AccountingVoucher @relation(fields: [voucherId], references: [id])
  organizationId   String    @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id])

  @@index([voucherId], name: "idx_sync_session_voucher")
  @@map("sync_sessions")
}
