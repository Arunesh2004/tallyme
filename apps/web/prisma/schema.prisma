generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id             String    @id @default(uuid())
  name           String
  gstin          String?
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  users          User[]
  roles          Role[]
  systemSettings SystemSetting[]
  auditLogs      AuditLog[]
  businessRules  BusinessRule[]
  notifications  Notification[]
  eventOutbox    EventOutbox[]
  failedEvents   FailedEvent[]
  processingHist ProcessingHistory[]
  accountingVouchers AccountingVoucher[]
  accountingLedgers  AccountingLedger[]
  accountingMasters  AccountingMaster[]
  syncMetrics        SyncMetric[]
  
  // Inventory Bounded Context
  inventoryStockGroups      InventoryStockGroup[]
  inventoryStockCategories  InventoryStockCategory[]
  inventoryUnits            InventoryUnit[]
  inventoryGodowns          InventoryGodown[]
  inventoryPriceLevels      InventoryPriceLevel[]
  inventoryBatches          InventoryBatch[]
  inventoryStockItems       InventoryStockItem[]

  // Student Fees Bounded Context
  ingestionMessages         IngestionMessage[]
  manualReviews             ManualReview[]

  // Student Information System
  feeHeads                  FeeHead[]
  feeStructures             FeeStructure[]
  studentProfiles           StudentProfile[]
  feeTransactions           FeeTransaction[]

  // Accounting Mapper
  ledgerMappings            LedgerMapping[]
  accountingTransactions    AccountingTransaction[]

  // Sync Integration
  syncSessions              SyncSession[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  organizationId String    @map("organization_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])
  userRoles      UserRole[]

  @@index([organizationId], name: "idx_users_organization_id")
  @@map("users")
}

model Role {
  id             String    @id @default(uuid())
  name           String
  organizationId String    @map("organization_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])
  permissions    Permission[]
  userRoles      UserRole[]

  @@index([organizationId], name: "idx_roles_organization_id")
  @@map("roles")
}

model Permission {
  id             String    @id @default(uuid())
  action         String
  resource       String
  roleId         String    @map("role_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  role           Role      @relation(fields: [roleId], references: [id])

  @@index([roleId], name: "idx_permissions_role_id")
  @@map("permissions")
}

model UserRole {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  roleId         String    @map("role_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  user           User      @relation(fields: [userId], references: [id])
  role           Role      @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId], name: "uq_user_roles_user_role")
  @@index([userId], name: "idx_user_roles_user_id")
  @@map("user_roles")
}

model SystemSetting {
  id             String    @id @default(uuid())
  key            String
  value          Json
  organizationId String    @map("organization_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key], name: "uq_system_settings_org_key")
  @@index([organizationId], name: "idx_system_settings_org_id")
  @@map("system_settings")
}

model AuditLog {
  id             String    @id @default(uuid())
  action         String
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id")
  diff           Json
  organizationId String    @map("organization_id")
  
  // Lifecycle (Append only, no updates/deletes)
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String?   @map("created_by")

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityType, entityId], name: "idx_audit_logs_org_entity")
  @@map("audit_logs")
}

model BusinessRule {
  id             String    @id @default(uuid())
  name           String
  category       String
  conditionJson  Json      @map("condition_json")
  actionJson     Json      @map("action_json")
  isActive       Boolean   @default(true) @map("is_active")
  organizationId String    @map("organization_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedBy      String?   @map("deleted_by")
  version        Int       @default(1)

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, category], name: "idx_business_rules_org_cat")
  @@map("business_rules")
}

model ProcessingHistory {
  id             String    @id @default(uuid())
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id")
  state          String
  payload        Json
  organizationId String    @map("organization_id")
  
  // Lifecycle (Append only)
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String?   @map("created_by")

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityId], name: "idx_processing_history_org_entity")
  @@map("processing_history")
}

enum SyncStatus {
  PENDING
  QUEUED
  PROCESSING
  SYNCED
  FAILED
  RETRYING
  DEAD_LETTER
  CONFLICT
}

enum EventStatus {
  PENDING
  PROCESSING
  RETRYING
  PUBLISHED
  FAILED
}

model EventOutbox {
  id             String      @id @default(uuid())
  eventId        String      @unique @default(uuid()) @map("event_id")
  aggregateId    String      @map("aggregate_id")
  aggregateType  String      @map("aggregate_type")
  eventType      String      @map("event_type")
  payload        Json
  correlationId  String?     @map("correlation_id")
  status         EventStatus @default(PENDING)
  retryCount     Int         @default(0) @map("retry_count")
  lastError      String?     @map("last_error")
  processedAt    DateTime?   @map("processed_at")
  organizationId String      @map("organization_id")
  
  // Lifecycle
  createdAt      DateTime    @default(now()) @map("created_at")

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([status, createdAt], name: "idx_event_outbox_status")
  @@index([organizationId], name: "idx_event_outbox_org_id")
  @@map("event_outbox")
}

model FailedEvent {
  id             String    @id @default(uuid())
  eventType      String    @map("event_type")
  payload        Json
  errorReason    String    @map("error_reason")
  retryCount     Int       @default(0) @map("retry_count")
  organizationId String    @map("organization_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId], name: "idx_failed_events_org_id")
  @@map("failed_events")
}

model Notification {
  id             String    @id @default(uuid())
  type           String
  message        String
  isRead         Boolean   @default(false) @map("is_read")
  recipientId    String    @map("recipient_id")
  organizationId String    @map("organization_id")
  
  // Audit & Lifecycle
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([recipientId, isRead], name: "idx_notifications_recipient_read")
  @@index([organizationId], name: "idx_notifications_org_id")
  @@map("notifications")
}

model AccountingVoucher {
  id                      String      @id @default(uuid())
  accountingTransactionId String?     @unique @map("accounting_transaction_id")
  voucherNumber           String?     @map("voucher_number")
  tallyId                 String?     @map("tally_id")
  voucherType             String      @map("voucher_type")
  date                    DateTime
  narration               String?
  syncStatus              SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt              DateTime?   @map("last_sync_at")
  syncAttempts            Int         @default(0) @map("sync_attempts")
  lastSyncError           String?     @map("last_sync_error")
  xmlRequest              String?     @map("xml_request")
  xmlResponse             String?     @map("xml_response")
  
  // Lifecycle Metadata
  validatedAt             DateTime?   @map("validated_at")
  queuedAt                DateTime?   @map("queued_at")
  syncedAt                DateTime?   @map("synced_at")
  failedAt                DateTime?   @map("failed_at")
  retryCount              Int         @default(0) @map("retry_count")
  lastFailureReason       String?     @map("last_failure_reason")
  
  // Audit & Lifecycle
  correlationId           String?     @map("correlation_id")
  sourceSystem            String      @default("TallyMe") @map("source_system")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  createdBy               String?     @map("created_by")
  updatedBy               String?     @map("updated_by")

  organizationId          String      @map("organization_id")
  organization            Organization @relation(fields: [organizationId], references: [id])
  accountingTransaction   AccountingTransaction? @relation(fields: [accountingTransactionId], references: [id])
  entries                 VoucherEntry[]
  syncSessions            SyncSession[]
  
  @@map("accounting_vouchers")
}

model VoucherEntry {
  id             String      @id @default(uuid())
  voucherId      String      @map("voucher_id")
  ledgerId       String      @map("ledger_id")
  isDebit        Boolean     @map("is_debit")
  amount         Decimal
  narration      String?

  voucher        AccountingVoucher @relation(fields: [voucherId], references: [id])
  ledger         AccountingLedger  @relation(fields: [ledgerId], references: [id])

  @@index([voucherId], name: "idx_voucher_entry_voucher")
  @@map("voucher_entries")
}

model AccountingLedger {
  id             String      @id @default(uuid())
  name           String
  tallyId        String?     @map("tally_id")
  parentGroup    String      @map("parent_group")
  isActive       Boolean     @default(true) @map("is_active")
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  // Relations
  ledgerMappings   LedgerMapping[]
  accountingEntries AccountingEntry[]
  voucherEntries    VoucherEntry[]

  @@map("accounting_ledgers")
}

model AccountingMaster {
  id             String      @id @default(uuid())
  masterType     String      @map("master_type")
  name           String
  tallyId        String?     @map("tally_id")
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")

  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")
  
  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("accounting_masters")
}

model SyncMetric {
  id             String      @id @default(uuid())
  eventId        String      @map("event_id")
  aggregateId    String      @map("aggregate_id")
  aggregateType  String      @map("aggregate_type")
  status         String      // SUCCESS, FAILED
  durationMs     Int         @map("duration_ms")
  retryCount     Int         @default(0) @map("retry_count")
  errorReason    String?     @map("error_reason")
  
  // Lifecycle
  createdAt      DateTime    @default(now()) @map("created_at")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([status, createdAt], name: "idx_sync_metrics_status")
  @@index([organizationId], name: "idx_sync_metrics_org_id")
  @@map("sync_metrics")
}

// ==========================================
// INVENTORY BOUNDED CONTEXT
// ==========================================

model InventoryStockGroup {
  id             String      @id @default(uuid())
  name           String
  tallyId        String?     @map("tally_id")
  parentGroup    String?     @map("parent_group")
  payload        Json
  syncStatus     SyncStatus  @default(PENDING) @map("sync_status")
  
  // Sync Metadata
  lastSyncAt     DateTime?   @map("last_sync_at")
  syncAttempts   Int         @default(0) @map("sync_attempts")
  lastSyncError  String?     @map("last_sync_error")
  xmlRequest     String?     @map("xml_request")
  xmlResponse    String?     @map("xml_response")

  // Audit & Lifecycle
  correlationId  String?     @map("correlation_id")
  sourceSystem   String      @default("TallyMe") @map("source_system")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  updatedBy      String?     @map("updated_by")

  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("inventory_stock_groups")
