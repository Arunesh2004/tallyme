# Environment
NODE_ENV=development # development | test | production
PORT=3000

# Security (MUST BE CHANGED IN PRODUCTION)
JWT_SECRET=super_secret_key_change_me_in_prod
JWT_EXPIRATION=1h
CORS_ORIGINS=http://localhost:3001,https://app.tallyme.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tallyme?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Worker specific
WORKER_ID=main-worker-1
WORKER_MODE=false # Set to true to run background jobs instead of API

# Tally ERP
TALLY_HOST=127.0.0.1
TALLY_PORT=9000
TALLY_TIMEOUT_MS=30000
TALLY_COMPANY_NAME=TallyMe Demo Corp

# Providers (AI / OCR)
# AI_PROVIDER_API_KEY=sk-...
# OCR_PROVIDER_API_KEY=...